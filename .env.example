# ── Find Your Vertical — Environment Variables ──
#
# VITE_ vars are Vite build-time values. Set in:
#   - local dev: .env (git-ignored) — loaded automatically by Vite
#   - production: in the build environment before `npm run build && npx wrangler deploy`
#     (Cloudflare Workers, not Pages — use `wrangler secret put` or set in your CI/CD)

# Creator-facing CTA destination. When set, the Explore Creator Services button
# in the "Continue Your Creator Journey" report section navigates here.
# Defaults to the local FYV /creator-services route when unset.
VITE_FYV_CREATOR_SERVICES_URL=

# Internal cockpit URLs (only override if cockpit is hosted separately)
# VITE_FYV_CREATOR_COCKPIT_URL=
# VITE_FYV_QUALIFY_OPPORTUNITY_URL=

# Strategy call booking page (defaults to Calendly)
# VITE_FYV_STRATEGY_CALL_URL=https://calendly.com/mikegrobinson/20-min

# Internal manual-review destination
# VITE_FYV_MANUAL_REVIEW_URL=

# ── FYV-PERSONA-1B — Worker secrets (server-side ONLY; never VITE_) ──
#
# These are Cloudflare Worker secrets consumed by worker/index.ts +
# worker/provider.ts for POST /api/personas/generate. Set them with
# `wrangler secret put <NAME>` (production) or in a git-ignored .dev.vars file
# (local `wrangler dev`). They MUST NOT be exposed to the browser — do not add a
# VITE_ prefix and never import them into src/.
#
# Supabase project URL (same project as VITE_SUPABASE_URL, without the prefix).
# SUPABASE_URL=
# Anon key — used only to validate the caller's bearer token via /auth/v1/user.
# SUPABASE_ANON_KEY=
# Service-role key — used for the SECURITY DEFINER generation RPCs. SECRET.
# SUPABASE_SERVICE_ROLE_KEY=
#
# Provider selection: 'openai' (any OpenAI-compatible endpoint) or 'fixture'
# (deterministic offline personas for dev/test; refused when PERSONA_APP_ENV
# is 'production'). Defaults to 'openai' when unset.
# PERSONA_PROVIDER=fixture
# PERSONA_PROVIDER_BASE_URL=https://api.openai.com/v1
# PERSONA_PROVIDER_API_KEY=
# PERSONA_MODEL=gpt-4o-mini
# Set to 'production' in the live environment so fixture mode fails closed.
# PERSONA_APP_ENV=development
